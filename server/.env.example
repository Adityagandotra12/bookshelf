NODE_ENV=development
PORT=3001
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Database (MySQL / TiDB Cloud). TiDB often uses port 4000; MySQL uses 3306.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bookshelf
DB_SSL=false

# CORS: allowed frontend origin(s). Use FRONTEND_URL for Vercel URL. Comma-separated for multiple.
FRONTEND_URL=http://localhost:5173
# CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info

# Optional: password-reset email (see EMAIL_AND_PASSWORD_RESET.md)
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# EMAIL_FROM=your@gmail.com
# EMAIL_FROM_NAME=Bookshelf Helpdesk

# Optional: used for reset link in email when different from FRONTEND_URL
# BACKEND_URL=https://your-app.onrender.com
